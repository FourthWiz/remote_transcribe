# Meeting Transcriber — Configuration
# Copy to config.env and edit, or run:  bash setup.sh

# Input folder containing .m4a / .mp3 recordings
MEETINGS_DIR=~/Desktop/Meetings

# Output folder for Markdown transcripts
NOTES_DIR=~/Desktop/Meetings/Notes

# Optional: copy every transcript here too (leave empty to disable)
COPY_DIR=

# Whisper model: tiny | base | small | medium | large-v2 | large-v3
# medium = good balance of speed and accuracy (~3-5 min per hour on Apple Silicon)
# large-v3 = best accuracy (~8-12 min per hour on Apple Silicon)
WHISPER_MODEL=medium

# Cron schedule (HH:MM, 24-hour)
CRON_TIME=10:15

# Set to false to skip cron setup
CRON_ENABLED=true
